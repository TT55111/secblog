---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<div class="tags-cloud">
  {tags.map(tag => (
    <a href={`/search/?q=${encodeURIComponent(tag)}`} class="tag-item">
      {tag}
    </a>
  ))}
</div>

<style>
  .tags-cloud {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .tag-item {
    font-family: 'Fira Code', monospace;
    font-size: 12px;
    padding: 8px 18px;
    border: 1px solid #00ff4115;
    border-radius: 2px;
    color: #4a7a4a;
    cursor: pointer;
    transition: all 0.3s;
    text-decoration: none;
    position: relative;
  }

  .tag-item::before {
    content: '#';
    color: #00ff41;
    margin-right: 2px;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .tag-item:hover::before {
    opacity: 1;
  }

  .tag-item:hover {
    border-color: #00ff41;
    color: #00ff41;
    background: #00ff4133;
    box-shadow: 0 0 15px #00ff4133;
    transform: scale(1.05);
  }
</style>
