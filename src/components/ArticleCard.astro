---
interface Props {
  collection: 'ctf' | 'vuln';
  category: string;
  date: Date;
  title: string;
  excerpt: string;
  tags: string[];
  href: string;
}

const { collection, category, date, title, excerpt, tags, href } = Astro.props;
---

<a href={href} class="article-card">
  <div class="article-meta">
    <span class:list={['article-category', collection === 'ctf' ? 'cat-ctf' : 'cat-vuln']}>
      {category}
    </span>
    <span class="article-date">{date.toLocaleDateString('zh-CN')}</span>
  </div>
  <h3 class="article-title">{title}</h3>
  <p class="article-excerpt">{excerpt}</p>
  <div class="article-tags">
    {tags.map(tag => (
      <span class="article-tag">{tag}</span>
    ))}
  </div>
</a>

<style>
  .article-card {
    display: block;
    background: #0a140a;
    border: 1px solid #00ff4115;
    border-radius: 4px;
    padding: 28px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    text-decoration: none;
  }

  .article-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 0;
    background: #00ff41;
    box-shadow: 0 0 10px #00ff41;
    transition: height 0.4s;
  }

  .article-card:hover {
    border-color: #00ff4133;
    background: #0f1f0f;
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0, 255, 65, 0.08);
  }

  .article-card:hover::before {
    height: 100%;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }

  .article-category {
    font-family: 'Fira Code', monospace;
    font-size: 10px;
    padding: 3px 10px;
    border-radius: 2px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .cat-ctf {
    background: rgba(0, 240, 255, 0.1);
    color: #00f0ff;
    border: 1px solid rgba(0, 240, 255, 0.2);
  }

  .cat-vuln {
    background: rgba(255, 0, 64, 0.1);
    color: #ff0040;
    border: 1px solid rgba(255, 0, 64, 0.2);
  }

  .article-date {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    color: #4a7a4a;
  }

  .article-title {
    font-family: 'Rajdhani', sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: #c0ffc0;
    margin-bottom: 10px;
    line-height: 1.3;
    transition: color 0.3s;
  }

  .article-card:hover .article-title {
    color: #00ff41;
  }

  .article-excerpt {
    font-size: 14px;
    color: #4a7a4a;
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .article-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .article-tag {
    font-family: 'Fira Code', monospace;
    font-size: 10px;
    color: #4a7a4a;
    padding: 2px 8px;
    border: 1px solid #00ff4115;
    border-radius: 2px;
    transition: all 0.3s;
  }

  .article-tag:hover {
    border-color: #00ff41;
    color: #00ff41;
  }
</style>
