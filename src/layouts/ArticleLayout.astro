---
import BaseLayout from './BaseLayout.astro';
import GiscusComments from '../components/GiscusComments';

interface Props {
  title: string;
  description?: string;
  category?: string;
  categoryType?: 'ctf' | 'vuln';
  date?: Date;
  tags?: string[];
  breadcrumbs?: { label: string; href: string }[];
}

const {
  title,
  description = '',
  category,
  categoryType = 'ctf',
  date,
  tags = [],
  breadcrumbs = [],
} = Astro.props;
---

<BaseLayout title={`${title} — SecBlog`} description={description}>
  <article class="article-detail" data-pagefind-body>
    {breadcrumbs.length > 0 && (
      <nav class="breadcrumb" data-pagefind-ignore>
        {breadcrumbs.map((crumb, i) => (
          <>
            {i > 0 && <span class="separator">/</span>}
            <a href={crumb.href}>{crumb.label}</a>
          </>
        ))}
      </nav>
    )}

    <header class="detail-header" data-pagefind-ignore>
      {category && (
        <span class:list={['detail-category', categoryType === 'ctf' ? 'cat-ctf' : 'cat-vuln']}>
          {category}
        </span>
      )}
      <h1 class="detail-title">{title}</h1>
      <div class="detail-meta">
        {date && (
          <span class="meta-item">📅 {date.toLocaleDateString('zh-CN')}</span>
        )}
      </div>
    </header>

    <div class="detail-content">
      <slot />
    </div>

    <footer class="detail-footer" data-pagefind-ignore>
      {tags.length > 0 && (
        <div class="detail-tags">
          {tags.map(tag => (
            <span class="detail-tag">#{tag}</span>
          ))}
        </div>
      )}
      <div class="giscus-container">
        <GiscusComments client:visible term={Astro.url.pathname} />
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .article-detail {
    max-width: 860px;
    margin: 0 auto;
    padding: 60px 40px;
  }

  .breadcrumb {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    color: #4a7a4a;
    margin-bottom: 32px;
    letter-spacing: 1px;
  }

  .breadcrumb a {
    color: #00ff41;
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-shadow: 0 0 8px #00ff4133;
  }

  .separator {
    margin: 0 8px;
  }

  .detail-header {
    margin-bottom: 40px;
    padding-bottom: 32px;
    border-bottom: 1px solid #00ff4115;
  }

  .detail-category {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    padding: 4px 14px;
    border-radius: 2px;
    letter-spacing: 2px;
    display: inline-block;
    margin-bottom: 16px;
  }

  .cat-ctf {
    background: rgba(0, 240, 255, 0.1);
    color: #00f0ff;
    border: 1px solid rgba(0, 240, 255, 0.2);
  }

  .cat-vuln {
    background: rgba(255, 0, 64, 0.1);
    color: #ff0040;
    border: 1px solid rgba(255, 0, 64, 0.2);
  }

  .detail-title {
    font-family: 'Orbitron', sans-serif;
    font-size: 32px;
    font-weight: 800;
    color: #00ff41;
    letter-spacing: 2px;
    line-height: 1.3;
    margin-bottom: 16px;
    text-shadow: 0 0 20px #00ff4133;
  }

  .detail-meta {
    display: flex;
    gap: 24px;
    font-family: 'Fira Code', monospace;
    font-size: 12px;
    color: #4a7a4a;
  }

  .detail-content {
    font-size: 16px;
    line-height: 1.8;
  }

  .detail-content :global(h2) {
    font-family: 'Orbitron', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: #00ff41;
    margin: 40px 0 16px;
    letter-spacing: 2px;
    padding-left: 16px;
    border-left: 3px solid #00ff41;
    text-shadow: 0 0 10px #00ff4133;
  }

  .detail-content :global(pre) {
    background: #050e05;
    border: 1px solid #00ff4115;
    border-radius: 4px;
    padding: 20px 24px;
    margin: 20px 0;
    overflow-x: auto;
  }

  .detail-content :global(code) {
    font-family: 'Fira Code', monospace;
    font-size: 13px;
  }

  .detail-content :global(p code) {
    background: rgba(0, 255, 65, 0.08);
    color: #00ff41;
    padding: 2px 8px;
    border-radius: 2px;
    border: 1px solid #00ff4133;
  }

  .detail-footer {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid #00ff4115;
  }

  .detail-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .detail-tag {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    padding: 4px 12px;
    border: 1px solid #00ff4115;
    border-radius: 2px;
    color: #4a7a4a;
    transition: all 0.3s;
  }

  .detail-tag:hover {
    border-color: #00ff41;
    color: #00ff41;
    background: #00ff4133;
  }

  .giscus-container {
    margin-top: 32px;
  }

  @media (max-width: 768px) {
    .article-detail { padding: 40px 16px; }
    .detail-title { font-size: 24px; }
  }
</style>
