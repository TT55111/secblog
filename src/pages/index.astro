---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="hero">
    <h1 class="hero-name">TT</h1>
    <p class="hero-subtitle">探索未知漏洞 · 攻防之间寻找真理</p>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 20px 80px;
  }

  .hero-name {
    font-family: 'Orbitron', sans-serif;
    font-size: 96px;
    font-weight: 900;
    color: #00ff41;
    letter-spacing: 8px;
    text-shadow: 0 0 10px #00ff41, 0 0 40px #00ff4133, 0 0 80px #00ff4133;
  }

  .hero-subtitle {
    font-family: 'Fira Code', monospace;
    font-size: 16px;
    color: #4a7a4a;
    margin-top: 20px;
    letter-spacing: 3px;
  }
</style>
