---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('vuln');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const severityLabels: Record<string, string> = {
  Critical: '严重',
  High: '高危',
  Medium: '中危',
  Low: '低危',
};

const statusLabels: Record<string, string> = {
  patched: '已修复',
  reported: '已报告',
  unpatched: '未修复',
};
---

<ArticleLayout
  title={post.data.title}
  description={`${post.data.type} ${post.data.severity} 级别漏洞分析`}
  category={`漏洞 · ${post.data.type}`}
  categoryType="vuln"
  date={post.data.date}
  tags={post.data.tags}
  breadcrumbs={[
    { label: '首页', href: '/' },
    { label: '漏洞分析', href: '/vuln/' },
  ]}
>
  <div class="vuln-meta-bar">
    {post.data.cve && (
      <div class="vuln-meta-item">
        <span class="meta-label">CVE</span>
        <span class="meta-value cve-id">{post.data.cve}</span>
      </div>
    )}
    <div class="vuln-meta-item">
      <span class="meta-label">严重程度</span>
      <span class:list={['meta-value', `sev-${post.data.severity.toLowerCase()}`]}>
        {post.data.severity} · {severityLabels[post.data.severity]}
      </span>
    </div>
    <div class="vuln-meta-item">
      <span class="meta-label">状态</span>
      <span class:list={['meta-value', `status-${post.data.status}`]}>
        {statusLabels[post.data.status]}
      </span>
    </div>
  </div>
  <Content />
</ArticleLayout>

<style>
  .vuln-meta-bar {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 32px;
    padding: 16px 20px;
    background: #0a0a14;
    border: 1px solid #ff004015;
    border-radius: 4px;
  }

  .vuln-meta-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .meta-label {
    font-family: 'Fira Code', monospace;
    font-size: 10px;
    color: #7a4a4a;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .meta-value {
    font-family: 'Fira Code', monospace;
    font-size: 12px;
    padding: 2px 10px;
    border-radius: 2px;
  }

  .cve-id {
    color: #00f0ff;
    border: 1px solid rgba(0, 240, 255, 0.2);
    background: rgba(0, 240, 255, 0.05);
  }

  .sev-critical { color: #ff0040; border: 1px solid rgba(255, 0, 64, 0.3); background: rgba(255, 0, 64, 0.05); }
  .sev-high { color: #ff8c00; border: 1px solid rgba(255, 140, 0, 0.3); background: rgba(255, 140, 0, 0.05); }
  .sev-medium { color: #ffe600; border: 1px solid rgba(255, 230, 0, 0.3); background: rgba(255, 230, 0, 0.05); }
  .sev-low { color: #00ff41; border: 1px solid rgba(0, 255, 65, 0.3); background: rgba(0, 255, 65, 0.05); }

  .status-patched { color: #00ff41; }
  .status-reported { color: #ffe600; }
  .status-unpatched { color: #ff0040; }

  @media (max-width: 768px) {
    .vuln-meta-bar { flex-direction: column; gap: 12px; }
  }
</style>
