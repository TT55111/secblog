---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — 页面未找到">
  <section class="error-section">
    <div class="glitch-wrapper">
      <h1 class="error-code" data-text="404">404</h1>
    </div>
    <div class="terminal-output">
      <p><span class="prompt">$</span> curl -I {Astro.url.pathname}</p>
      <p class="error-line">HTTP/1.1 404 Not Found</p>
      <p class="error-line">Content-Type: text/error</p>
      <p class="error-line">X-Reason: Page does not exist</p>
      <p><span class="prompt">$</span> <span class="cursor">_</span></p>
    </div>
    <p class="error-message">你访问的页面不存在，可能已被移动或删除。</p>
    <div class="error-actions">
      <a href="/" class="action-btn primary">返回首页</a>
      <a href="/search/" class="action-btn secondary">搜索内容</a>
    </div>
    <div class="ascii-art">
      <pre>
    ╔══════════════════════════════╗
    ║  ACCESS DENIED               ║
    ║  ────────────────────────    ║
    ║  The page you are looking    ║
    ║  for has been moved or       ║
    ║  does not exist.             ║
    ║                              ║
    ║  > Return to base? [Y/n]     ║
    ╚══════════════════════════════╝
      </pre>
    </div>
  </section>
</BaseLayout>

<style>
  .error-section {
    position: relative;
    z-index: 2;
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 40px;
    text-align: center;
  }

  .glitch-wrapper {
    margin-bottom: 32px;
  }

  .error-code {
    font-family: 'Orbitron', sans-serif;
    font-size: clamp(80px, 15vw, 160px);
    font-weight: 900;
    color: #ff0040;
    letter-spacing: 16px;
    position: relative;
    text-shadow: 0 0 20px #ff004033, 0 0 60px #ff004033;
    animation: glitch-skew 4s infinite linear alternate-reverse;
  }

  .error-code::before,
  .error-code::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .error-code::before {
    color: #00f0ff;
    animation: glitch-effect 3s infinite linear alternate-reverse;
    clip-path: polygon(0 0, 100% 0, 100% 45%, 0 45%);
    transform: translate(-3px, -2px);
    opacity: 0.7;
  }

  .error-code::after {
    color: #00ff41;
    animation: glitch-effect 2s infinite linear alternate-reverse;
    clip-path: polygon(0 55%, 100% 55%, 100% 100%, 0 100%);
    transform: translate(3px, 2px);
    opacity: 0.7;
  }

  @keyframes glitch-effect {
    0% { transform: translate(0); }
    20% { transform: translate(-3px, 3px); }
    40% { transform: translate(-3px, -3px); }
    60% { transform: translate(3px, 3px); }
    80% { transform: translate(3px, -3px); }
    100% { transform: translate(0); }
  }

  @keyframes glitch-skew {
    0% { transform: skew(0deg); }
    20% { transform: skew(-1deg); }
    40% { transform: skew(0.5deg); }
    60% { transform: skew(-0.5deg); }
    80% { transform: skew(1deg); }
    100% { transform: skew(0deg); }
  }

  .terminal-output {
    font-family: 'Fira Code', monospace;
    font-size: 13px;
    color: #4a7a4a;
    margin-bottom: 32px;
    line-height: 2;
  }

  .prompt {
    color: #00ff41;
    margin-right: 8px;
  }

  .error-line {
    color: #ff0040;
    padding-left: 20px;
  }

  .cursor {
    color: #00ff41;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .error-message {
    font-family: 'Fira Code', monospace;
    font-size: 14px;
    color: #7a4a4a;
    margin-bottom: 32px;
  }

  .error-actions {
    display: flex;
    gap: 16px;
    margin-bottom: 48px;
  }

  .action-btn {
    font-family: 'Fira Code', monospace;
    font-size: 12px;
    padding: 12px 28px;
    border-radius: 4px;
    text-decoration: none;
    letter-spacing: 2px;
    transition: all 0.3s;
  }

  .action-btn.primary {
    background: #ff004033;
    color: #ff0040;
    border: 1px solid #ff0040;
  }

  .action-btn.primary:hover {
    background: #ff0040;
    color: #020a02;
    box-shadow: 0 0 20px #ff004033;
  }

  .action-btn.secondary {
    background: transparent;
    color: #4a7a4a;
    border: 1px solid #00ff4133;
  }

  .action-btn.secondary:hover {
    border-color: #00ff41;
    color: #00ff41;
    box-shadow: 0 0 12px #00ff4133;
  }

  .ascii-art {
    font-family: 'Fira Code', monospace;
    font-size: 11px;
    color: #4a7a4a;
    opacity: 0.5;
  }

  .ascii-art pre {
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .error-section { padding: 60px 16px; }
    .error-actions { flex-direction: column; }
    .ascii-art { display: none; }
  }
</style>
